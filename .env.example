# .env.example — Copy to .env and fill in your values

# ── Backend selection ──
# "gemini" = FREE (Google Gemini API + ChromaDB)
# "azure"  = Azure AI Foundry (requires subscription)
BACKEND=gemini

# ── Gemini backend (free) ──
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Azure backend (if BACKEND=azure) ──
PROJECT_ENDPOINT=https://<your-hub>.services.ai.azure.com/api
MODEL_DEPLOYMENT=gpt-4o-deploy
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=rg-ai-fund-demo
AZURE_PROJECT_NAME=ai-fund-agent
